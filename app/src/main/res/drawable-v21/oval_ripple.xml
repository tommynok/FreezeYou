<?xml version="1.0" encoding="utf-8"?>
<ripple xmlns:android="http://schemas.android.com/apk/res/android"
    android:color="?android:colorPrimary">
    <item>
        <layer-list>
            <!-- Translucent halo so the button reads against busy/colorful backgrounds
                 (e.g. grid-mode app icons behind it), regardless of theme. -->
            <item>
                <shape android:shape="oval">
                    <solid android:color="#66000000" />
                </shape>
            </item>
            <item
                android:top="6dp"
                android:bottom="6dp"
                android:left="6dp"
                android:right="6dp">
                <shape android:shape="oval">
                    <solid android:color="?android:colorAccent" />
                </shape>
            </item>
        </layer-list>
    </item>
</ripple>
